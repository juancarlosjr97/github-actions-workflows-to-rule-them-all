{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>juancarlosjr97/renovate-configuration#main",
        "github>juancarlosjr97/renovate-configuration//presets/internal-tooling-circular#main"
    ],
    "packageRules": [
        {
            "description": "Pin actions/checkout to v5 series only - v6 is not compatible with Docker container actions (see actions/checkout#2359)",
            "matchManagers": [
                "github-actions"
            ],
            "matchPackageNames": [
                "actions/checkout"
            ],
            "allowedVersions": ">=5.0.0 <6.0.0"
        },
        {
            "description": "Internal shared-tooling repositories intentionally track main/master and are excluded from Renovate update churn in this circular tooling ecosystem.",
            "matchPackageNames": [
                "juancarlosjr97/pre-commit-to-rule-them-all",
                "juancarlosjr97/github-actions-workflows-to-rule-them-all",
                "juancarlosjr97/release-it-containerized",
                "juancarlosjr97/renovate-configuration"
            ],
            "matchSourceUrls": [
                "https://github.com/juancarlosjr97/pre-commit-to-rule-them-all",
                "https://github.com/juancarlosjr97/github-actions-workflows-to-rule-them-all",
                "https://github.com/juancarlosjr97/release-it-containerized",
                "https://github.com/juancarlosjr97/renovate-configuration"
            ],
            "enabled": false
        }
    ],
    "customManagers": [
        {
            "description": "Automate bumping the skills CLI major version used in the skills-sh-update workflow",
            "customType": "regex",
            "managerFilePatterns": [
                "/^\\.github/workflows/shared-agents-skills-sh\\.yml$/"
            ],
            "matchStrings": [
                "npx -y skills@(?<currentValue>\\d+)"
            ],
            "depNameTemplate": "skills",
            "datasourceTemplate": "npm",
            "versioningTemplate": "npm"
        }
    ]
}
