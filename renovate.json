{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>juancarlosjr97/renovate-configuration#0.1.5"
    ],
    "packageRules": [
        {
            "description": "Pin actions/checkout to v5 series only - v6 is not compatible with Docker container actions (see actions/checkout#2359)",
            "matchManagers": ["github-actions"],
            "matchPackageNames": ["actions/checkout"],
            "allowedVersions": ">=5.0.0 <6.0.0"
        }
    ]
}
